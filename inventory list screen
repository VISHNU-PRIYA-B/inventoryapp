import 'package:flutter/material.dart';
import 'package:graphql_flutter/graphql_flutter.dart';

const String getInventoryQuery = r'''
  query {
    inventoryItems {
      itemName
      size
      length
      itemType
      quantity
      location
      imagePath
    }
    issuedItems {
      id
      itemName
      status
      issuedAt
      issuedTo {
        name
      }
    }
  }
''';

class InventoryListScreen extends StatelessWidget {
  const InventoryListScreen({super.key});

  final String baseUrl = "http://192.168.68.113:8000";

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xFF0A0E1A),

      appBar: AppBar(
        backgroundColor: const Color(0xFF0A0E1A),
        elevation: 0,
        title: const Text(
          "Lists",
          style: TextStyle(color: Color(0xFFC9A227)),
        ),
        iconTheme: const IconThemeData(color: Colors.white),
      ),

      body: Query(
        options: QueryOptions(
          document: gql(getInventoryQuery),
          fetchPolicy: FetchPolicy.networkOnly,
        ),

        builder: (result, {fetchMore, refetch}) {

          if (result.isLoading) {
            return const Center(
              child: CircularProgressIndicator(color: Colors.white),
            );
          }

          if (result.hasException) {
            return Center(
              child: Text(
                result.exception.toString(),
                style: const TextStyle(color: Colors.red),
              ),
            );
          }

          final List issued = result.data?['issuedItems'] ?? [];
          final List items  = result.data?['inventoryItems'] ?? [];

          // Sort issued by issuedAt ascending so latest accepted user wins
          final sortedIssued = List.from(issued);
          sortedIssued.sort((a, b) {
            final aTime = a['issuedAt'] ?? '';
            final bTime = b['issuedAt'] ?? '';
            return aTime.compareTo(bTime); // oldest first → newest last (overwrites)
          });

          // Build map: itemName → latest accepted user name
          final Map<String, String> acceptedUserMap = {};

          for (final issued_item in sortedIssued) {
            final status = (issued_item['status'] ?? '').toString().toLowerCase();
            final issuedTo = issued_item['issuedTo'];
            final name = (issuedTo != null && issuedTo['name'] != null)
                ? issuedTo['name'].toString().trim()
                : '';

            // Only map if accepted and name is not empty
            if (status == 'accepted' && name.isNotEmpty) {
              final itemName = issued_item['itemName'] ?? '';
              acceptedUserMap[itemName] = name; // latest accepted overwrites older
            }
          }

          return SingleChildScrollView(
            scrollDirection: Axis.horizontal,
            child: SingleChildScrollView(
              child: DataTable(

                headingRowColor: MaterialStateProperty.all(
                    const Color(0xFF1A2035)),

                dataRowColor: MaterialStateProperty.all(
                    const Color(0xFF0A0E1A)),

                columns: const [
                  DataColumn(label: Text("Item",
                      style: TextStyle(color: Colors.white))),
                  DataColumn(label: Text("Type",
                      style: TextStyle(color: Colors.white))),
                  DataColumn(label: Text("Size",
                      style: TextStyle(color: Colors.white))),
                  DataColumn(label: Text("Length",
                      style: TextStyle(color: Colors.white))),
                  DataColumn(label: Text("Location",
                      style: TextStyle(color: Colors.white))),
                  DataColumn(label: Text("Qty",
                      style: TextStyle(color: Colors.white))),
                  DataColumn(label: Text("Image",
                      style: TextStyle(color: Colors.white))),
                  DataColumn(label: Text("User",
                      style: TextStyle(color: Colors.white))),
                ],

                rows: items.map<DataRow>((item) {
                  final itemName  = item['itemName'] ?? '';
                  final imagePath = item['imagePath'];

                  // Show latest accepted user for this item, else '-'
                  final userName = acceptedUserMap[itemName] ?? '-';

                  return DataRow(cells: [

                    DataCell(Text(itemName,
                        style: const TextStyle(color: Colors.white))),

                    DataCell(Text(item['itemType'] ?? '',
                        style: const TextStyle(color: Colors.white))),

                    DataCell(Text(item['size'] ?? '',
                        style: const TextStyle(color: Colors.white))),

                    DataCell(Text(item['length'] ?? '',
                        style: const TextStyle(color: Colors.white))),

                    DataCell(Text(item['location'] ?? '',
                        style: const TextStyle(color: Colors.white))),

                    DataCell(Text(item['quantity'].toString(),
                        style: const TextStyle(
                            color: Colors.white,
                            fontWeight: FontWeight.bold))),

                    // Image view button
                    DataCell(
                      (imagePath != null && imagePath.toString().trim().isNotEmpty && imagePath.toString().trim() != 'nan')
                          ? ElevatedButton(
                              style: ElevatedButton.styleFrom(
                                backgroundColor: const Color(0xFFC9A227),
                              ),
                              onPressed: () {
                                showDialog(
                                  context: context,
                                  builder: (_) => Dialog(
                                    backgroundColor: const Color(0xFF1A2035),
                                    child: Padding(
                                      padding: const EdgeInsets.all(10),
                                      child: Image.network(
                                        "$baseUrl$imagePath",
                                        fit: BoxFit.contain,
                                        loadingBuilder: (context, child,
                                            loadingProgress) {
                                          if (loadingProgress == null) {
                                            return child;
                                          }
                                          return const SizedBox(
                                            height: 150,
                                            child: Center(
                                              child: CircularProgressIndicator(
                                                  color: Colors.white),
                                            ),
                                          );
                                        },
                                        errorBuilder:
                                            (context, error, stackTrace) {
                                          return const Text(
                                            "Failed to load image",
                                            style: TextStyle(color: Colors.red),
                                          );
                                        },
                                      ),
                                    ),
                                  ),
                                );
                              },
                              child: const Text(
                                "View",
                                style: TextStyle(color: Colors.black),
                              ),
                            )
                          : const Text(
                              "No Image",
                              style: TextStyle(color: Colors.grey),
                            ),
                    ),

                    // User column: '-' until admin accepts, then shows latest user
                    DataCell(Text(
                      userName,
                      style: TextStyle(
                        color: userName == '-'
                            ? Colors.white38
                            : const Color(0xFFC9A227),
                      ),
                    )),
                  ]);
                }).toList(),
              ),
            ),
          );
        },
      ),
    );
  }
}
